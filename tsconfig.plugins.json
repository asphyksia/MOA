{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": ["./gateway/node_modules/@types", "./types"]
  },
  "include": [".opencode/plugins/**/*.ts", "types/**/*.d.ts"]
}
