# opencore Gateway configuration. Copy to .env and fill in.

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Port for the local opencode server the gateway starts (default 4096+ range)
OPENCORE_GATEWAY_PORT=4099

# Default agent for new chats: chat | dev | plan (default: chat)
# SECURITY: 'chat' is read-only-ish (no bash). Only raise to 'dev' if you
# accept remote code execution on this machine from authorized Telegram users.
OPENCORE_GATEWAY_DEFAULT_AGENT=chat

# Optional: working directory the agent operates in (default: current dir)
# OPENCORE_GATEWAY_WORKDIR=C:\path\to\project

# Optional: explicit path to the opencode executable (auto-detected if unset)
# OPENCORE_OPENCODE_BIN=C:\Users\you\AppData\Local\pi-node\current\node_modules\opencode-ai\bin\opencode.exe

# Optional: override the state root directory (default: ~/.opencore).
# Affects the gateway's allowlist AND every plugin store (memory, sessions,
# codebase, budget, skills, embeddings config). Useful when running under a
# different user profile, inside containers, or to keep state in a project
# directory you control.
# OPENCORE_STATE_DIR=C:\path\to\state\root

# Optional: available models for the /models command (comma-separated "id:label" pairs).
# Example: OPENCORE_MODELS="anthropic/claude-opus-4:Claude Opus 4,openai/gpt-4o:GPT-4o"
# If not set, defaults to a common set: Claude Opus 4, Claude Sonnet 4, GPT-4o, o1, Gemini 2.0 Flash.
# OPENCORE_MODELS=

# Optional: default model (if not set, opencode's configured model is used)
# OPENCORE_DEFAULT_MODEL=anthropic/claude-opus-4
