{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "dev",
  "model": "{env:MOA_MODEL}",
  "small_model": "{env:MOA_SMALL_MODEL}",
  "autoupdate": false,
  "lsp": true,
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "rm -rf *": "deny",
      "rm -rf /": "deny",
      "sudo *": "deny",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "ls *": "allow",
      "cat *": "allow"
    }
  },
  "plugin": []
}
